# Supabase Credentials (obtain from Supabase Dashboard -> Project Settings -> API)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase JWT Secret (Dashboard -> Project Settings -> API -> JWT Secret)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# External Data Source Endpoints (FBIL and DBIE endpoints)
FBIL_ENDPOINT_URL=https://fbil.org.in/some/endpoint/path
DBIE_ENDPOINT_URL=https://dbie.rbi.org.in/some/endpoint/path

# Internal Security Key (used to secure /internal/* endpoints)
INTERNAL_SERVICE_KEY=your_internal_service_key_here
